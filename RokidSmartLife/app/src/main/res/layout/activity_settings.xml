<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="10dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="10dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="高德地图 API Key"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/api_key_guide"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/input_api_key"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="@string/api_key_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:background="@drawable/search_input_bg"
            android:inputType="text"
            android:singleLine="true"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <!-- Default Address -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="默认地址（定位失败时使用）"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="支持具体地址，如：武汉大学、珞珈山街道XX公寓"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/input_default_city"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="输入地址或地名"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:background="@drawable/search_input_bg"
            android:inputType="text"
            android:singleLine="true"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <!-- Search Radius -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_radius"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingTop="16dp"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btn_radius_decrease"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="◀"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_focus_bg"
                android:focusable="true" />

            <TextView
                android:id="@+id/radius_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_radius_increase"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_focus_bg"
                android:focusable="true" />
        </LinearLayout>

        <!-- Save Button -->
        <TextView
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="@string/save"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_focus_bg"
            android:focusable="true"
            android:layout_marginTop="20dp" />

        <!-- Version Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="智慧生活 v1.0.0 for Rokid"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingTop="16dp" />

    </LinearLayout>
</ScrollView>
