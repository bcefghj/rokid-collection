<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/plan_index"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF1A73E8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingEnd="10dp" />

        <TextView
            android:id="@+id/plan_duration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/plan_cost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFAB40"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/plan_night"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 夜间"
            android:textColor="#FFFF6B35"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/plan_route"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFB0B0B0"
        android:textSize="12sp"
        android:paddingTop="4dp"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
