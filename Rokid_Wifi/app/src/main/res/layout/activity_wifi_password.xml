<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <FrameLayout
        android:layout_gravity="bottom"
        android:layout_width="match_parent"
        android:layout_height="480px">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="20px"
            android:paddingEnd="20px">

            <!-- WiFi名称 -->
            <TextView
                android:id="@+id/tv_ssid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="24px"
                android:textColor="@color/green_normal"
                android:textFontWeight="600"
                android:gravity="center"
                android:singleLine="true"
                android:layout_marginTop="12px"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 已输入的密码 -->
            <TextView
                android:id="@+id/tv_password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="28px"
                android:textColor="@color/green_normal"
                android:textFontWeight="500"
                android:minHeight="40px"
                android:gravity="center_vertical|center_horizontal"
                android:background="@drawable/bg_wifi_selected"
                android:paddingStart="12px"
                android:paddingEnd="12px"
                android:layout_marginTop="10px"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_ssid" />

            <!-- 键盘区域 横向滚动 -->
            <HorizontalScrollView
                android:id="@+id/keyboard_scroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="16px"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_password">

                <LinearLayout
                    android:id="@+id/keyboard_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4px"
                    android:paddingEnd="4px" />
            </HorizontalScrollView>

            <!-- 状态提示 -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="20px"
                android:textColor="@color/green_normal_60"
                android:gravity="center"
                android:layout_marginTop="12px"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/keyboard_scroll" />

            <ProgressBar
                android:id="@+id/loading"
                android:layout_width="36px"
                android:layout_height="36px"
                android:visibility="gone"
                android:indeterminate="true"
                android:indeterminateTint="@color/green_normal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_status"
                android:layout_marginTop="8px" />

            <!-- 操作提示 -->
            <TextView
                android:id="@+id/tv_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="滑动选择  单击确认  后滑返回"
                android:textSize="16px"
                android:textColor="@color/green_normal_40"
                android:layout_marginBottom="4px"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</FrameLayout>
